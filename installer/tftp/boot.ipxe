#!ipxe

echo IRIS Ubuntu Auto-Installer
echo ===========================

dhcp
echo IP: ${net0/ip}

echo Loading kernel...
kernel http://192.168.1.107:8080/vmlinuz ip=dhcp url=http://192.168.1.107:8080/iris-ubuntu-autoinstall.iso autoinstall ds=nocloud-net;s=http://192.168.1.107:8080/autoinstall/

echo Loading initrd...
initrd http://192.168.1.107:8080/initrd

echo Booting...
boot
