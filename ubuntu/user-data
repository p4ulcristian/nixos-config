#cloud-config
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us

  # Auto-select first disk
  storage:
    layout:
      name: direct

  # Network (DHCP)
  network:
    network:
      version: 2
      ethernets:
        id0:
          match:
            driver: "*"
          dhcp4: true

  # User account
  identity:
    hostname: iris-server
    username: iris
    # Password: nixos (hashed)
    password: "$6$rounds=4096$xyz$LBK4p1zGQ5W8z3kSx8D8w8Z5j.R5q3qV5oE8H5q3q3q3q3q3q3q3q3q3q3q3q3q3q3q3q3q3"

  # SSH
  ssh:
    install-server: true
    allow-pw: false
    authorized-keys:
      - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIG5858m5yHShPBI6j6W0UtKZcDtNXM3MTwEmb5B9Gv7d
      - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIBnfnRzOc3sOQTnxWO3ticIlORvQeexu/Yudhfd+I0HI
      - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIEOlBKLnsb1oPzscTGGB7QPPNIa8iMYLV2TRjMZUSKXx

  # Packages
  packages:
    - git
    - curl
    - zsh
    - build-essential

  # Post-install
  late-commands:
    # Enable passwordless sudo for iris
    - echo 'iris ALL=(ALL) NOPASSWD:ALL' > /target/etc/sudoers.d/iris
    - chmod 440 /target/etc/sudoers.d/iris

    # Set zsh as default shell
    - curtin in-target --target=/target -- chsh -s /bin/zsh iris

    # Install Nix as iris user
    - curtin in-target --target=/target -- su - iris -c 'curl -L https://nixos.org/nix/install | sh -s -- --daemon --yes'

    # Clone config
    - curtin in-target --target=/target -- su - iris -c 'git clone https://github.com/p4ulcristian/nixos-config ~/.config/nixos'

    # Create first-boot service to run home-manager
    - |
      cat > /target/etc/systemd/system/iris-setup.service << 'EOF'
      [Unit]
      Description=IRIS First Boot Setup
      After=network-online.target nix-daemon.service
      Wants=network-online.target

      [Service]
      Type=oneshot
      User=iris
      ExecStart=/home/iris/.config/nixos/ubuntu/first-boot.sh
      RemainAfterExit=true

      [Install]
      WantedBy=multi-user.target
      EOF
    - curtin in-target --target=/target -- systemctl enable iris-setup.service
